name: 'gemini分流'
desc: 'gemini分流至新加坡，含OpenRouter分流及广告屏蔽'
proxy-groups:
  - name: "singapore"
    type: url-test
    include-all: true
    url: "http://www.gstatic.com/generate_204"
    interval: 600
    tolerance: 50
    lazy: true
    filter: '新加坡'

  - name: "OpenRouter"
    type: url-test
    include-all: true
    url: "http://www.gstatic.com/generate_204"
    interval: 600
    tolerance: 50
    lazy: true
    filter: '(美国|新加坡)'

rule-providers:
  gemini:
    type: http
    behavior: classical
    url: "https://cdn.jsdelivr.net/gh/blackmatrix7/ios_rule_script@master/rule/Clash/Gemini/Gemini.yaml"
    interval: 86400

  reject:
    type: http
    behavior: domain
    url: "https://cdn.jsdelivr.net/gh/Loyalsoldier/clash-rules@release/reject.txt"
    interval: 86400

rules:
  - RULE-SET,reject,REJECT
  - DOMAIN-KEYWORD,openrouter.ai,OpenRouter
  - RULE-SET,gemini,singapore
